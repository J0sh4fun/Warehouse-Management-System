# Frontend (Next.js)
# ==============================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/*.tsbuildinfo

# Frontend environment files
frontend/.env*
!frontend/.env.example

# Lockfile policy: keep npm lockfile, ignore pnpm lockfile
frontend/pnpm-lock.yaml
pnpm-lock.yaml

